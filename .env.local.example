# Taskora Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional: Mapbox for advanced map features
# NEXT_PUBLIC_MAP_TOKEN=your_mapbox_access_token

# Optional: Cloudinary for image uploads
# NEXT_PUBLIC_CLOUDINARY_NAME=your_cloudinary_name

# Optional: Razorpay Public Key (if handling payments on frontend)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx

# Development
# NEXT_PUBLIC_DEBUG=false
